---
import { plumbingServices, electricalServices } from "../data/services";
---

<footer class="bg-text text-white">
  {/* Main Footer */}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      {/* Brand Column */}
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-4 group">
          <img src="/favicon.svg" alt="Plomeros Multiservicios" class="h-12 transition-transform duration-300 group-hover:scale-110" />
          <span class="font-heading font-extrabold text-lg leading-none tracking-tight">
            Plomeros<br /><span class="text-secondary">Multiservicios</span>
          </span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          Somos expertos en plomería y electricidad doméstica en Cali. Brindamos soluciones rápidas, seguras y garantizadas para tu hogar.
        </p>
        <div class="flex gap-3 mt-5">
          <a href="https://wa.me/573155533085" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-secondary transition-colors" aria-label="WhatsApp">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      {/* Plumbing Services */}
      <div>
        <h3 class="font-heading font-bold text-white text-sm uppercase tracking-wider mb-4">
          Plomería
        </h3>
        <ul class="space-y-2.5">
          {plumbingServices.map((s) => (
            <li>
              <a href={`/servicios/${s.slug}`} class="text-gray-400 text-sm hover:text-secondary transition-colors">
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Electrical Services */}
      <div>
        <h3 class="font-heading font-bold text-white text-sm uppercase tracking-wider mb-4">
          Electricidad
        </h3>
        <ul class="space-y-2.5">
          {electricalServices.map((s) => (
            <li>
              <a href={`/servicios/${s.slug}`} class="text-gray-400 text-sm hover:text-secondary transition-colors">
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Contact Info */}
      <div>
        <h3 class="font-heading font-bold text-white text-sm uppercase tracking-wider mb-4">
          Contacto
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-secondary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div class="text-sm">
              <a href="tel:3155533085" class="text-gray-400 hover:text-secondary transition-colors block">315 553 3085</a>
              <a href="tel:3184689368" class="text-gray-400 hover:text-secondary transition-colors block mt-1">318 468 9368</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-secondary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div class="text-sm text-gray-400">
              <p>Lunes a Viernes</p>
              <p class="mt-1">7:00 AM – 6:00 PM</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-secondary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm text-gray-400">Cali, Colombia</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  {/* Bottom Bar */}
  <div class="bg-gray-50 border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col items-center justify-center text-center gap-6">
        <p class="text-gray-500 text-sm font-medium">
          &copy; {new Date().getFullYear()} Plomeros Multiservicios. Todos los derechos reservados.
        </p>
        <a href="https://praxiuz.com" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-2 text-gray-400 text-xs hover:text-secondary transition-colors group">
          <span class="uppercase tracking-widest font-bold text-[10px] text-gray-400 group-hover:text-secondary transition-colors">Desarrollado por</span>
          <img src="/Praxiuz.svg" alt="Praxiuz" class="h-8 md:h-10 w-auto opacity-80 hover:opacity-100 transition-all filter grayscale hover:grayscale-0" />
        </a>
      </div>
    </div>
  </div>
</footer>
