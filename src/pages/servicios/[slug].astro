---
import MainLayout from "../../layouts/MainLayout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import ImagePlaceholder from "../../components/ImagePlaceholder.astro";
import { allServices, plumbingServices, electricalServices } from "../../data/services";
import { getServiceIcon } from "../../data/icons";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = () => {
  return allServices.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
};

const { service } = Astro.props;

const iconColor = service.category === "plomeria" ? "text-secondary" : "text-accent";
const iconBg = service.category === "plomeria" ? "bg-secondary/10" : "bg-accent/10";
const categoryLabel = service.category === "plomeria" ? "Plomería" : "Electricidad";
const badgeColor = service.category === "plomeria" ? "bg-secondary/10 text-secondary" : "bg-accent/10 text-accent";
const iconSvg = getServiceIcon(service.icon, iconColor);

// Get related services (same category, excluding current)
const sameCategoryServices = (service.category === "plomeria" ? plumbingServices : electricalServices)
  .filter((s) => s.slug !== service.slug);
const relatedServices = sameCategoryServices.slice(0, 3);
---

<MainLayout title={service.title} description={service.shortDescription}>

  {/* Breadcrumb + Header */}
  <section class="bg-gradient-to-br from-accent/5 via-white to-secondary/5 py-12 md:py-16 overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Breadcrumb */}
      <nav class="flex items-center gap-2 text-sm text-text-light mb-8 animate-fade-in">
        <a href="/" class="hover:text-secondary transition-colors">Inicio</a>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <a href="/servicios" class="hover:text-secondary transition-colors">Servicios</a>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-text font-medium truncate">{service.title}</span>
      </nav>

      <div class="flex items-start gap-4 md:gap-6 animate-slide-up animation-delay-200">
        <div class:list={["w-14 h-14 md:w-16 md:h-16 rounded-2xl flex items-center justify-center shrink-0 animate-scale-in", iconBg]}>
          <Fragment set:html={iconSvg.replace('w-6 h-6', 'w-7 h-7 md:w-8 md:h-8')} />
        </div>
        <div>
          <span class:list={["inline-block text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-full mb-2 animate-fade-in animation-delay-400", badgeColor]}>
            {categoryLabel}
          </span>
          <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-extrabold text-text leading-tight animate-slide-up animation-delay-400">
            {service.title}
          </h1>
        </div>
      </div>
    </div>
  </section>

  {/* Content */}
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
        {/* Main Content */}
        <div class="lg:col-span-3 animate-slide-up">
          <ImagePlaceholder
            src={service.image}
            alt={service.imagePlaceholder}
            text={service.imagePlaceholder}
            className="rounded-2xl mb-8 shadow-lg hover:scale-[1.02] transition-transform duration-500 h-[250px] sm:h-[350px] lg:h-[400px] w-full"
          />

          <div class="prose prose-lg max-w-none">
            <p class="text-text-light leading-relaxed text-base md:text-lg">
              {service.longDescription}
            </p>
          </div>

          {/* Features */}
          <div class="mt-10 bg-bg-alt rounded-2xl p-6 md:p-8">
            <h2 class="font-heading text-xl font-bold mb-4">¿Qué incluye este servicio?</h2>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-secondary shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-text-light text-sm">Diagnóstico y evaluación del problema</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-secondary shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-text-light text-sm">Mano de obra calificada</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-secondary shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-text-light text-sm">Materiales de primera calidad</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-secondary shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-text-light text-sm">Garantía de trabajo realizado</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-secondary shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-text-light text-sm">Limpieza del área de trabajo al finalizar</span>
              </li>
            </ul>
          </div>
        </div>

        {/* Sidebar */}
        <div class="lg:col-span-2 space-y-6">
          {/* CTA Card */}
          <div class="bg-gradient-to-br from-accent to-accent-dark rounded-2xl p-6 text-white sticky top-24">
            <h3 class="font-heading text-xl font-bold mb-2 text-white/90">¿Necesitas este servicio?</h3>
            <p class="text-white/60 text-sm mb-6">Contáctanos para una cotización sin compromiso.</p>

            <div class="space-y-3">
              <a
                href="/contacto"
                class="flex items-center justify-center gap-2 w-full bg-secondary hover:bg-secondary-dark text-white font-semibold py-3 px-6 rounded-xl transition-all duration-300"
              >
                Solicitar cotización
              </a>
              <a
                href="https://wa.me/573155533085"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full bg-white/10 hover:bg-white/20 text-white font-semibold py-3 px-6 rounded-xl transition-all duration-300 border border-white/20"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
              <a
                href="tel:3155533085"
                class="flex items-center justify-center gap-2 w-full bg-white/10 hover:bg-white/20 text-white font-semibold py-3 px-6 rounded-xl transition-all duration-300 border border-white/20"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Llamar: 315 553 3085
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Related Services */}
  {relatedServices.length > 0 && (
    <section class="py-12 md:py-16 bg-bg-alt">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-2xl md:text-3xl font-bold mb-8 text-center">
          Otros servicios que te pueden interesar
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedServices.map((s) => (
            <ServiceCard
              title={s.title}
              description={s.shortDescription}
              href={`/servicios/${s.slug}`}
              icon={s.icon}
              category={s.category}
            />
          ))}
        </div>
      </div>
    </section>
  )}

</MainLayout>
