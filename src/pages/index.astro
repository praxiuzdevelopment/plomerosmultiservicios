---
import MainLayout from "../layouts/MainLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ImagePlaceholder from "../components/ImagePlaceholder.astro";
import {
  plumbingServices,
  electricalServices,
  allServices,
} from "../data/services";
---

<MainLayout
  title="Plomeros y Electricistas en Cali"
  description="Plomeros y electricistas a domicilio en Cali, Jamundí y Palmira. Destape de cañerías sin romper, detección de fugas con geófono y reparaciones eléctricas urgentes. Cotización sin costo. Llama al 315 553 3085."
>
  {/* Hero Section */}
  <section
    class="relative bg-gradient-to-br from-accent/5 via-white to-secondary/5 overflow-hidden"
  >
    {/* Background decoration */}
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div
        class="absolute -top-24 -right-24 w-96 h-96 bg-secondary/5 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute -bottom-24 -left-24 w-96 h-96 bg-accent/5 rounded-full blur-3xl"
      >
      </div>
    </div>

    <div
      class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16 lg:py-20"
    >
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="text-center lg:text-left">
          <div
            class="inline-flex items-center gap-2 bg-secondary/10 text-secondary text-sm font-semibold px-4 py-1.5 rounded-full mb-6 animate-fade-in"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Servicio en Cali, Colombia
          </div>
          <h1
            class="font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-text leading-tight mb-6 animate-slide-up animation-delay-200"
          >
            <span class="text-secondary">Plomeros</span> y
            <span class="text-accent">electricistas</span>
            a domicilio en Cali
          </h1>
          <p
            class="text-text-light text-lg md:text-xl leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0 animate-slide-up animation-delay-400"
          >
            Destape de cañerías sin romper, detección de fugas con geófono y
            reparaciones eléctricas urgentes en Cali, Jamundí y Palmira.
            Técnicos con experiencia y trabajo garantizado.
          </p>
          <div
            class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start animate-slide-up animation-delay-600"
          >
            <a
              href="/contacto"
              class="inline-flex items-center justify-center gap-2 bg-secondary hover:bg-secondary-dark text-white font-semibold px-8 py-4 rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-secondary/30 hover:-translate-y-0.5"
            >
              Solicitar cotización
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a
              href="tel:3155533085"
              onclick="return gtag_report_conversion('tel:3155533085')"
              class="inline-flex items-center justify-center gap-2 bg-white border-2 border-accent text-accent font-semibold px-8 py-4 rounded-full hover:bg-accent hover:text-white transition-all duration-300"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              Llamar ahora
            </a>
          </div>

          {/* Trust indicators */}
          <div
            class="flex flex-wrap items-center gap-6 mt-10 justify-center lg:justify-start"
          >
            <div class="flex items-center gap-2 text-sm text-text-light">
              <svg
                class="w-5 h-5 text-secondary"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              Trabajo garantizado
            </div>
            <div class="flex items-center gap-2 text-sm text-text-light">
              <svg
                class="w-5 h-5 text-secondary"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              Servicio rápido
            </div>
            <div class="flex items-center gap-2 text-sm text-text-light">
              <svg
                class="w-5 h-5 text-secondary"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
              </svg>
              Precios justos
            </div>
          </div>
        </div>

        <div class="relative">
          <ImagePlaceholder
            src="/Hero_Image.jpeg"
            alt="equipo de plomeros profesionales trabajando"
            text="equipo de plomeros profesionales trabajando"
            className="rounded-2xl shadow-2xl h-[300px] sm:h-[400px] lg:h-[450px] w-full"
          />
          {/* Floating card */}
          <div
            class="absolute -bottom-6 -left-6 bg-white rounded-xl shadow-xl p-4 hidden md:flex items-center gap-3 border border-border"
          >
            <div
              class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center"
            >
              <svg
                class="w-6 h-6 text-secondary"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm font-bold text-text">Atención rápida</p>
              <p class="text-xs text-text-light">Lunes a Viernes</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* About Section */}
  <section class="py-16 md:py-24 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-slide-up">
          <ImagePlaceholder
            src="/Nosotros.jpg"
            alt="plomero profesional con herramientas de trabajo"
            text="plomero profesional con herramientas de trabajo"
            className="rounded-2xl shadow-xl hover:scale-105 transition-transform duration-500 h-[250px] sm:h-[350px] w-full"
          />
        </div>
        <div class="animate-fade-in animation-delay-200">
          <span
            class="text-secondary font-semibold text-sm uppercase tracking-wider"
            >Sobre nosotros</span
          >
          <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2 mb-6">
            ¿Quiénes somos?
          </h2>
          <p class="text-text-light leading-relaxed mb-4">
            <strong>Plomeros Multiservicios</strong> es una empresa dedicada a ofrecer
            soluciones integrales de plomería y electricidad para hogares en la ciudad
            de Cali. Contamos con un equipo de técnicos capacitados y con experiencia
            que garantizan un trabajo limpio, seguro y de calidad.
          </p>
          <p class="text-text-light leading-relaxed mb-6">
            Nos especializamos en atender emergencias y realizar instalaciones,
            reparaciones y mantenimientos preventivos. Nuestra prioridad es la
            satisfacción del cliente y la seguridad de tu hogar.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div
              class="bg-bg-alt rounded-xl p-4 text-center hover:shadow-md transition-shadow"
            >
              <p class="text-2xl font-bold text-secondary">2+</p>
              <p class="text-sm text-text-light mt-1">Años de experiencia</p>
            </div>
            <div
              class="bg-bg-alt rounded-xl p-4 text-center hover:shadow-md transition-shadow"
            >
              <p class="text-2xl font-bold text-secondary">100+</p>
              <p class="text-sm text-text-light mt-1">Clientes satisfechos</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Services Section */}
  <section class="py-16 md:py-24 bg-bg-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-slide-up">
        <span
          class="text-secondary font-semibold text-sm uppercase tracking-wider"
          >Lo que hacemos</span
        >
        <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2 mb-4">
          Nuestros Servicios
        </h2>
        <p class="text-text-light max-w-2xl mx-auto">
          Ofrecemos una amplia gama de servicios de plomería y electricidad
          doméstica para mantener tu hogar en perfecto estado.
        </p>
      </div>

      {/* Plumbing */}
      <div class="mb-10">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 2.25c0 0-6.75 8.25-6.75 12a6.75 6.75 0 1013.5 0c0-3.75-6.75-12-6.75-12z"
              ></path>
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-accent">Plomería</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {
            plumbingServices.map((service) => (
              <ServiceCard
                title={service.title}
                description={service.shortDescription}
                href={`/servicios/${service.slug}`}
                icon={service.icon}
                category={service.category}
              />
            ))
          }
        </div>
      </div>

      {/* Electrical */}
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-accent"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-accent">
            Electricidad
          </h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {
            electricalServices.map((service) => (
              <ServiceCard
                title={service.title}
                description={service.shortDescription}
                href={`/servicios/${service.slug}`}
                icon={service.icon}
                category={service.category}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* Why Choose Us */}
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span
          class="text-secondary font-semibold text-sm uppercase tracking-wider"
          >Nuestras ventajas</span
        >
        <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2 mb-4">
          ¿Por qué elegirnos?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div
          class="text-center p-6 rounded-2xl border border-border hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
        >
          <div
            class="w-14 h-14 rounded-xl bg-secondary/10 flex items-center justify-center mx-auto mb-4"
          >
            <svg
              class="w-7 h-7 text-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
              ></path>
            </svg>
          </div>
          <h3 class="font-heading font-bold text-accent text-lg mb-2">
            Trabajo garantizado
          </h3>
          <p class="text-text-light text-sm">
            Todos nuestros trabajos cuentan con garantía de calidad y
            satisfacción.
          </p>
        </div>

        <div
          class="text-center p-6 rounded-2xl border border-border hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
        >
          <div
            class="w-14 h-14 rounded-xl bg-secondary/10 flex items-center justify-center mx-auto mb-4"
          >
            <svg
              class="w-7 h-7 text-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-heading font-bold text-accent text-lg mb-2">
            Respuesta rápida
          </h3>
          <p class="text-text-light text-sm">
            Atendemos tus solicitudes de forma ágil para resolver tu problema lo
            antes posible.
          </p>
        </div>

        <div
          class="text-center p-6 rounded-2xl border border-border hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
        >
          <div
            class="w-14 h-14 rounded-xl bg-secondary/10 flex items-center justify-center mx-auto mb-4"
          >
            <svg
              class="w-7 h-7 text-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"
              ></path>
            </svg>
          </div>
          <h3 class="font-heading font-bold text-accent text-lg mb-2">
            Precios justos
          </h3>
          <p class="text-text-light text-sm">
            Ofrecemos tarifas competitivas sin costos ocultos. Cotización sin
            compromiso.
          </p>
        </div>

        <div
          class="text-center p-6 rounded-2xl border border-border hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
        >
          <div
            class="w-14 h-14 rounded-xl bg-secondary/10 flex items-center justify-center mx-auto mb-4"
          >
            <svg
              class="w-7 h-7 text-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
              ></path>
            </svg>
          </div>
          <h3 class="font-heading font-bold text-accent text-lg mb-2">
            Personal capacitado
          </h3>
          <p class="text-text-light text-sm">
            Técnicos con experiencia y capacitación constante en las mejores
            técnicas.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section
    class="py-16 md:py-20 bg-gradient-to-r from-accent to-accent-dark relative overflow-hidden"
  >
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div
        class="absolute top-0 right-0 w-72 h-72 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"
      >
      </div>
      <div
        class="absolute bottom-0 left-0 w-96 h-96 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"
      >
      </div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">
        ¿Tienes un problema en casa?
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">
        No dejes que un problema de plomería o electricidad arruine tu día.
        Contáctanos y te ayudamos con una solución rápida y profesional.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contacto"
          class="inline-flex items-center justify-center gap-2 bg-secondary hover:bg-secondary-dark text-white font-semibold px-8 py-4 rounded-full transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
        >
          Contáctanos ahora
        </a>
        <a
          href="https://wa.me/573155533085"
          target="_blank"
          rel="noopener noreferrer"
          onclick="gtag_whatsapp_conversion()"
          class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-full transition-all duration-300 border border-white/20"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          Escribir por WhatsApp
        </a>
      </div>
    </div>
  </section>
</MainLayout>
