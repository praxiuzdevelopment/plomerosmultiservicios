---
import MainLayout from "../layouts/MainLayout.astro";
import ContactForm from "../components/ContactForm.tsx";
import ImagePlaceholder from "../components/ImagePlaceholder.astro";
---

<MainLayout title="Contacto" description="Contáctanos para solicitar cotización de servicios de plomería y electricidad en Cali. Teléfonos: 315 553 3085 - 318 468 9368.">

  {/* Header */}
  <section class="bg-gradient-to-br from-accent/5 via-white to-secondary/5 py-16 md:py-20 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-secondary font-semibold text-sm uppercase tracking-wider animate-fade-in">Contáctanos</span>
      <h1 class="font-heading text-4xl md:text-5xl font-extrabold text-text mt-2 mb-4 animate-slide-up">
        ¿Cómo podemos ayudarte?
      </h1>
      <p class="text-text-light text-lg max-w-2xl mx-auto animate-fade-in animation-delay-200">
        Completa el formulario o comunícate directamente con nosotros. Estaremos encantados de atenderte.
      </p>
    </div>
  </section>

  {/* Contact Content */}
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        {/* Form */}
        <div class="lg:col-span-3 animate-slide-up">
          <div class="bg-white rounded-2xl border border-border p-6 md:p-8 shadow-sm hover:shadow-md transition-shadow">
            <h2 class="font-heading text-2xl font-bold mb-6">Envíanos un mensaje</h2>
            <ContactForm client:load />
          </div>
        </div>

        {/* Contact Info */}
        <div class="lg:col-span-2 space-y-6 animate-fade-in animation-delay-400">
          {/* Phones */}
          <div class="bg-bg-alt rounded-2xl p-6 hover:shadow-md transition-all hover:-translate-y-1">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <h3 class="font-heading font-bold text-accent">Teléfonos</h3>
            </div>
            <div class="space-y-3 pl-[52px]">
              <a href="tel:3155533085" onclick="return gtag_report_conversion('tel:3155533085')" class="flex items-center gap-2 text-text hover:text-secondary transition-colors font-medium">
                <span>315 553 3085</span>
              </a>
              <a href="tel:3184689368" onclick="return gtag_report_conversion('tel:3184689368')" class="flex items-center gap-2 text-text hover:text-secondary transition-colors font-medium">
                <span>318 468 9368</span>
              </a>
            </div>
          </div>

          {/* Hours */}
          <div class="bg-bg-alt rounded-2xl p-6 hover:shadow-md transition-all hover:-translate-y-1">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="font-heading font-bold text-accent">Horario de atención</h3>
            </div>
            <div class="space-y-2 pl-[52px]">
              <div class="flex justify-between text-sm">
                <span class="text-text font-medium">Lunes a Viernes</span>
                <span class="text-text-light">7:00 AM – 6:00 PM</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-text font-medium">Sábados</span>
                <span class="text-text-light">Emergencias</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-text font-medium">Domingos</span>
                <span class="text-text-light">Cerrado</span>
              </div>
            </div>
          </div>

          {/* Location */}
          <div class="bg-bg-alt rounded-2xl p-6 hover:shadow-md transition-all hover:-translate-y-1">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="font-heading font-bold text-accent">Zona de cobertura</h3>
            </div>
            <div class="pl-[52px]">
              <p class="text-text font-medium text-sm">Cali, Valle del Cauca</p>
              <p class="text-text-light text-sm mt-1">Cobertura en toda el área metropolitana (Jamundí, Yumbo y Candelaria)</p>
            </div>
          </div>

          {/* WhatsApp CTA */}
          <a
            href="https://wa.me/573155533085"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 bg-green-50 hover:bg-green-100 border border-green-200 rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg group"
          >
            <div class="w-12 h-12 rounded-xl bg-green-500 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="font-heading font-bold text-green-800">Escríbenos por WhatsApp</p>
              <p class="text-green-700 text-sm">Respuesta inmediata a tu consulta</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

</MainLayout>
